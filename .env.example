# Copy this file to `.env` in the repository root and fill in your own credentials.
# The loaders and query scripts read these variables via python-dotenv.

# Relational database (any PostgreSQL server, e.g. Neon, Supabase, local Postgres)
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# MongoDB (e.g. MongoDB Atlas or a local mongod)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=app
MONGODB_DB=electricity_demand
